# Production environment.
# Copy this file to .env and replace every placeholder before deployment.

# Compose port bindings. Keep 127.0.0.1 when publishing through a reverse proxy
# or Cloudflare Tunnel on the same host.
API_BIND_HOST=127.0.0.1
API_PUBLISHED_PORT=3001
API_CONTAINER_PORT=3001
WEB_BIND_HOST=127.0.0.1
WEB_PUBLISHED_PORT=3000
WEB_CONTAINER_PORT=3000

# Optional image tags used by docker-compose.yml.
RADIAL_API_IMAGE=radial-api:latest
RADIAL_WEB_IMAGE=radial-web:latest
RADIAL_MIGRATOR_IMAGE=radial-api-migrator:latest

# Postgres container. Use a strong password before deploying.
POSTGRES_USER=radial
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_DB=radial

# API
PORT=3001
DATABASE_URL="postgresql://radial:replace-with-a-strong-postgres-password@postgres:5432/radial?schema=public"
TRACKER_PUBLIC_URL="https://radial.example.com/api/v1"
TRACKER_USER_NAME="Radial API"
TRACKER_USER_EMAIL="radial-api@example.com"

# Use a long random value in production.
TRACKER_API_KEY="replace-with-a-long-random-production-token"

# Web server-side API URL. Inside compose, use the API service name.
TRACKER_API_BASE_URL="http://api:3001/api/v1"
