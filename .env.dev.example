# Development environment.
# Copy this file to .env before running docker compose with docker-compose.dev.yml.

# Compose port bindings
API_BIND_HOST=127.0.0.1
API_PUBLISHED_PORT=3001
API_CONTAINER_PORT=3001
WEB_BIND_HOST=127.0.0.1
WEB_PUBLISHED_PORT=3000
WEB_CONTAINER_PORT=3000

# Local Postgres container
POSTGRES_DB=radial
POSTGRES_USER=radial
POSTGRES_PASSWORD=radial

# API
PORT=3001
DATABASE_URL="postgresql://radial:radial@postgres:5432/radial?schema=public"
TRACKER_PUBLIC_URL="http://localhost:3001/api/v1"
TRACKER_USER_NAME="Radial API"
TRACKER_USER_EMAIL="radial-api@example.com"

# Shared API auth token used by the web app when calling the API.
TRACKER_API_KEY="dev-tracker-api-key"

# Web server-side API URL. In Docker development, use the compose service name.
TRACKER_API_BASE_URL="http://api:3001/api/v1"
